{
  "name": "ha-yahoofinance-board-card",
  "version": "0.0.0-dev",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:prod": "NODE_ENV=production rollup -c",
    "dev": "rollup -c --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "biome format --write src/ test/ && prettier --write \"**/*.md\"",
    "format:check": "biome format src/ test/ && prettier --check \"**/*.md\"",
    "lint": "biome lint src/ test/",
    "lint:fix": "biome lint --write src/ test/",
    "check": "biome check --write src/ test/",
    "check:fix": "biome check --write src/ test/",
    "typecheck": "tsc --noEmit",
    "check:ci": "tsc --noEmit && biome check src/ test/ && prettier --check \"**/*.md\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "ha-card-shared": "github:marcintk/ha-card-shared#v1.2.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "rollup": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "prettier": "ha-card-shared/prettier.config.json"
}
